# ── Base de données (Railway PostgreSQL — copie depuis Railway dashboard) ──────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/railway

# ── Redis (Railway Redis — copie depuis Railway dashboard) ────────────────────
REDIS_HOST=HOST
REDIS_PORT=6379
REDIS_PASSWORD=PASSWORD

# ── JWT (génère avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_ACCESS_SECRET=GENERE_UN_SECRET_ICI
JWT_REFRESH_SECRET=GENERE_UN_AUTRE_SECRET_ICI

# ── URLs production ───────────────────────────────────────────────────────────
FRONTEND_URL=https://elengi.vercel.app
NODE_ENV=production
PORT=3000

# ── Mail (Gmail App Password recommandé) ──────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=ton-email@gmail.com
MAIL_PASS=app-password-gmail
MAIL_FROM=Elengi <ton-email@gmail.com>

# ── Google OAuth (console.cloud.google.com) ───────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── Web Push VAPID (génère avec: npx web-push generate-vapid-keys) ────────────
VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx
VAPID_SUBJECT=mailto:ton-email@gmail.com
