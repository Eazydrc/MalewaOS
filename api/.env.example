# ══════════════════════════════════════════════════════
#  .env.example — copier vers .env et remplir les valeurs
#  NE JAMAIS committer .env dans git
# ══════════════════════════════════════════════════════

# ── Base de données ────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/malewaos?schema=public"

# ── JWT (générer avec: openssl rand -hex 32) ──────────
JWT_ACCESS_SECRET="CHANGE_ME_64_chars_minimum_use_openssl_rand_hex_32"
JWT_REFRESH_SECRET="CHANGE_ME_64_chars_minimum_use_openssl_rand_hex_32"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── Google OAuth ──────────────────────────────────────
# Créer les credentials sur https://console.cloud.google.com
GOOGLE_CLIENT_ID="XXXXXXXXXXXX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# ── Redis (OTP / MFA / sessions) ─────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ── Email (Nodemailer SMTP) ───────────────────────────
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USER="noreply@votre-domaine.cd"
MAIL_PASS="YOUR_APP_PASSWORD"
MAIL_FROM="Elengi <noreply@votre-domaine.cd>"

# ── Application ───────────────────────────────────────
PORT="3001"
BACKEND_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:4000"
NODE_ENV="development"

# ── Sécurité : compte Super Admin intouchable ─────────
# Mettre l'email du compte SUPER_ADMIN que personne ne peut désactiver/modifier
PROTECTED_SUPER_ADMIN_EMAIL="super-admin@votre-domaine.cd"

# ── Paiement Mobile (CinetPay) ────────────────────────
CINETPAY_API_KEY="YOUR_CINETPAY_API_KEY"
CINETPAY_SITE_ID="YOUR_CINETPAY_SITE_ID"

# ── Web Push (VAPID) ───────────────────────────────────
# Générer avec : node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY"
VAPID_SUBJECT="mailto:contact@votre-domaine.cd"
