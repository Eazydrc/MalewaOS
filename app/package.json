{
  "name": "elengi-app",
  "version": "1.0.0",
  "description": "Elengi — Restaurants Kinshasa",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:4000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "make-icon": "node scripts/make-icon.cjs"
  },
  "build": {
    "appId": "cd.elengi.app",
    "productName": "Elengi",
    "copyright": "Copyright © 2025 Elengi",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/package.json",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Elengi-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Elengi",
      "uninstallDisplayName": "Elengi",
      "installerSidebar": "build-resources/installer-sidebar.bmp",
      "deleteAppDataOnUninstall": false
    },
    "publish": null
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@ntbjs/react-components": "^2.0.11",
    "@tanstack/react-query": "^5.40.0",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.395.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.5",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.23.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^6.4.2",
    "wait-on": "^8.0.5"
  }
}
